# System Design MCP - Environment Configuration
# Copy to .env and fill in values

# LLM Provider: "openai" | "ollama"
LLM_PROVIDER=openai

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Optional: Load estimation defaults
DEFAULT_QPS_ESTIMATE=1000
DEFAULT_STORAGE_GB=100
