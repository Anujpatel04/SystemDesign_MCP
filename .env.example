# System Design MCP - Environment Configuration
# Copy to .env and fill in values. Never commit .env (it is in .gitignore).

# LLM Provider: "openai" | "azure" | "ollama"
LLM_PROVIDER=azure

# --- Azure OpenAI (when LLM_PROVIDER=azure) ---
# Base endpoint only, or full URL (path will be stripped automatically)
# Example: https://oai-nasco.openai.azure.com
AZURE_ENDPOINT=https://oai-nasco.openai.azure.com
# API key (env name can be AZURE_API_KEY or AZURE_KEY)
AZURE_KEY=your-azure-api-key
AZURE_API_VERSION=2025-01-01-preview
AZURE_DEPLOYMENT=gpt-4o

# --- OpenAI (when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o

# --- Ollama (when LLM_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Optional: Load estimation defaults
DEFAULT_QPS_ESTIMATE=1000
DEFAULT_STORAGE_GB=100
